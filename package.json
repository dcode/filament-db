{
  "name": "filament-db",
  "version": "1.53.1",
  "description": "Desktop and web app for managing 3D printing filament profiles",
  "author": {
    "name": "hyiger",
    "email": "hyiger@users.noreply.github.com"
  },
  "license": "(AGPL-3.0-or-later AND CC-BY-NC-ND-4.0)",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev -p 3456",
    "build": "next build",
    "start:prep": "node scripts/start-prep.mjs",
    "start": "npm run start:prep && node .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:compile": "esbuild electron/main.ts --bundle --platform=node --outfile=electron-dist/main.js --external:electron --external:@pokusew/pcsclite --external:mongodb-memory-server-core --external:mongodb && esbuild electron/preload.ts --bundle --platform=node --outfile=electron-dist/preload.js --external:electron",
    "electron:rebuild": "electron-rebuild -f -o @pokusew/pcsclite",
    "electron:dev": "npm run electron:rebuild && npm run electron:compile && concurrently \"next dev -p 3456\" \"wait-on http://localhost:3456 && electron .\"",
    "electron:build": "npm run build && npm run electron:fixlinks && npm run electron:rebuild && npm run electron:compile && npm run electron:pack",
    "electron:fixlinks": "node -e \"const fs=require('fs'),path=require('path');function fix(d){fs.readdirSync(d,{withFileTypes:true}).forEach(e=>{const f=path.join(d,e.name);if(e.isSymbolicLink()){const t=fs.realpathSync(f);fs.rmSync(f);fs.cpSync(t,f,{recursive:true})}else if(e.isDirectory())fix(f)})}fix('.next/standalone');fs.cpSync('.next/standalone','standalone',{recursive:true});fs.cpSync('.next/static','standalone/.next/static',{recursive:true});fs.cpSync('public','standalone/public',{recursive:true})\"",
    "electron:pack": "electron-builder --config electron-builder.yml",
    "label:print": "tsx scripts/print-label.ts",
    "label:sim": "tsx scripts/print-label-sim.ts",
    "fetch:reference": "node scripts/fetch-reference.mjs",
    "backfill:spools": "tsx scripts/backfill-spools.ts"
  },
  "dependencies": {
    "@pokusew/pcsclite": "^0.6.0",
    "bonjour-service": "^1.4.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "mongodb-memory-server-core": "^11.0.1",
    "mongoose": "^9.3.3",
    "next": "^16.2.4",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swagger-ui-react": "^5.32.1",
    "tar": "^7.5.16",
    "undici": "^6.25.0",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "tmp": "^0.2.6",
    "shell-quote": "^1.8.4",
    "joi": "^18.2.1",
    "esbuild": "^0.28.1",
    "@babel/core": "^7.29.1",
    "dompurify": "^3.4.11",
    "form-data": "^4.0.6",
    "js-yaml": "^4.2.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "mongodb-memory-server": "^11.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  }
}
